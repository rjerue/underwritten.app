{
  "name": "underwritten",
  "version": "0.0.3",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rjerue/underwritten.app.git"
  },
  "bin": {
    "underwritten": "./dist/cli.js"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { force: true, recursive: true })\" && tsc -p tsconfig.build.json && chmod +x dist/cli.js"
  },
  "dependencies": {
    "underwritten-bridge": "workspace:*",
    "underwritten-bridge-contract": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
