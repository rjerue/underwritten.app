{
  "name": "underwritten-mcp",
  "version": "0.0.1",
  "private": false,
  "license": "MIT",
  "bin": {
    "underwritten-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
