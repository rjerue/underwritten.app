{
  "name": "underwritten-mcp",
  "version": "0.0.6",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rjerue/underwritten.app.git"
  },
  "bin": {
    "underwritten-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { force: true, recursive: true })\" && tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "underwritten-bridge": "workspace:*",
    "underwritten-bridge-contract": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
